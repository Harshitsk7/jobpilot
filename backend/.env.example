# ──────────────── Database ────────────────
DATABASE_URL="file:./dev.db"

# ──────────────── Server ────────────────
PORT=3001

# ──────────────── AI Provider ────────────────
# Options: copilot | anthropic | openai | gemini
# You can also switch providers at runtime from Settings UI
LLM_PROVIDER=anthropic

# GitHub Copilot (if LLM_PROVIDER=copilot)
# GITHUB_COPILOT_TOKEN=
# GITHUB_COPILOT_APP_ID=
# COPILOT_MODEL=claude-sonnet-4-5-20250514

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google Gemini (if LLM_PROVIDER=gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────── Security ────────────────
# REQUIRED: 32+ character random string for encrypting credentials
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=change_this_to_a_long_random_string_min_32_chars

# ──────────────── Storage ────────────────
DATA_DIR=./data

# ──────────────── Playwright ────────────────
# Set to false to see the browser during scraping/apply
PLAYWRIGHT_HEADLESS=true
